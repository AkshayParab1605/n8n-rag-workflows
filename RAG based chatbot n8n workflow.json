      "parameters": {
        "formTitle": "Upload Document to Knowledge Base",
        "formDescription": "Upload a PDF, TXT, or DOCX file to add it to the RAG knowledge base. The document will be automatically chunked and stored in Pinecone.",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Document File",
