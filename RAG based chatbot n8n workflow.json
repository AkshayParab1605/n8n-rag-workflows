      "id": "7f41ecb1-d204-4065-a1db-56b44d4b9400",
      "name": "Upload Document Form",
      "type": "n8n-nodes-base.formTrigger",
      "typeVersion": 2.2,
      "position": [
        -160,
        704
      ],
      "webhookId": "191ce4a6-f886-42bf-8f7e-fa86021c3aa0"
    },
    {
      "parameters": {
        "jsCode": "// Extract uploaded file and metadata from form submission\nconst formData = $input.first().json;\nconst binaryData = $input.first().binary;\n\n// Get the uploaded file\nconst fileKey = Object.keys(binaryData || {})[0];\n\nif (!fileKey) {\n  throw new Error('No file was uploaded. Please upload a PDF, TXT, or DOCX file.');\n}\n\nconst file = binaryData[fileKey];\nconst description = formData['Document Description (optional)'] || 'No description provided';\nconst fileName = file.fileName || 'unknown_file';\n\nconsole.log(`Processing file: ${fileName}`);\n\nreturn [{\n  json: {\n    fileName,\n    fileDescription: description,\n    mimeType: file.mimeType,\n    uploadedAt: new Date().toISOString()\n  },\n  binary: {\n    data: file\n  }\n}];"
      },
      "id": "dee763ab-d830-4bbf-8ba1-e916771a66b5",
